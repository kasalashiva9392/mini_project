NODE_ENV=development
PORT=5000
CLIENT_URL=https://app.yourdomain.com
JWT_SECRET=e2614da1060a9a1485e073508c36a8a070695e234b92fd77820461188bdf5ae9
JWT_EXPIRES_IN=7d

DATABASE_URL=file:./dev.db

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LLM: use local Ollama (no API bill) OR OpenAI — Ollama wins if OLLAMA_BASE_URL is set
# Local Node: http://127.0.0.1:11434 — if the API runs in Docker, use http://host.docker.internal:11434 instead
OLLAMA_BASE_URL=
# e.g. llama3.2, mistral, phi3 — run: ollama pull <name>
OLLAMA_MODEL=llama3.2

# OpenAI (optional if Ollama is configured)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
