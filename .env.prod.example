# Copy to .env.prod and fill in for:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build
#
# Postgres is created automatically: database ucc, user ucc, password = POSTGRES_PASSWORD.

CLIENT_URL=https://your-frontend.example.com
JWT_SECRET=replace-with-long-random-string-at-least-10-chars
POSTGRES_PASSWORD=replace-with-strong-db-password
# Public URL the browser uses to call the API (include https in real prod)
VITE_API_URL=https://api.yourdomain.com

# Optional: local Ollama on the same host as Docker (macOS/Win Docker Desktop)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# Optional ports
# FRONTEND_PORT=8080
# BACKEND_PORT=5000
