# Copy to .env.prod and fill in for: docker compose -f docker-compose.prod.yml --env-file .env.prod up --build

CLIENT_URL=https://localhost:8080
JWT_SECRET=replace-with-long-random-string-at-least-10-chars
POSTGRES_PASSWORD=replace-with-strong-db-password
VITE_API_URL=http://localhost:5000

# Optional: local Ollama on the same host as Docker (macOS/Win Docker Desktop)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# Optional ports
# FRONTEND_PORT=8080
# BACKEND_PORT=5000
